{
  "name": "nexus-seos-monorepo",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm --recursive run build",
    "dev": "pnpm --parallel run dev",
    "test": "pnpm --recursive run test",
    "clean": "pnpm -r exec rimraf node_modules dist"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5"
  }
}
